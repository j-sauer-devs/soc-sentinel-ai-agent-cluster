# =============================================================================
# SOC Sentinel AI Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Only K2_API_KEY is required for AI features. Security API keys are optional
# (mock data is used when keys are missing).

# ---------------------------------------------------------------------------
# K2 Think LLM (Required for AI features)
# ---------------------------------------------------------------------------
K2_API_KEY=
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2

# ---------------------------------------------------------------------------
# Security API Keys (Optional — mock data used if missing)
# ---------------------------------------------------------------------------

# AbuseIPDB — IP reputation scoring
# Get key: https://www.abuseipdb.com/account/api
ABUSEIPDB_KEY=

# VirusTotal — Malware/IP/domain analysis
# Get key: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_KEY=

# AlienVault OTX — Threat intelligence pulses
# Get key: https://otx.alienvault.com/api
OTX_KEY=

# GreyNoise — Internet noise classification
# Get key: https://viz.greynoise.io/account/api-key
GREYNOISE_KEY=

# NIST NVD — CVE vulnerability database (optional, works without key)
# Get key: https://nvd.nist.gov/developers/request-an-api-key
NVD_KEY=

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend Configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
